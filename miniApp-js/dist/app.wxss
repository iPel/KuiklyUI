/**app.wxss**/
page {
  height: 100%;
  width: 100%;
  display: flex;
  flex-direction: column;
}

view {
  display: flex;
  flex-direction: column;
  position: relative;
  box-sizing: border-box;
  border: 0 solid black;
}

text {
  display: inline;
  box-sizing: border-box;
}

image {
  display: block;
  box-sizing: border-box;
}

.container {
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
}
